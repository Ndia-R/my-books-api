{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(tree -L 3 -I 'target|build|node_modules|.git' /workspace)",
      "Bash(docker-compose ps)",
      "Bash(find /workspace/src/main/java -name \"*.java\" -type f -exec grep -l \"Security\\|@PreAuthorize\\|@Secured\\|Authentication\" {})",
      "Bash(cat /workspace/.env)",
      "Bash(docker network ls)",
      "Bash(docker network inspect vsv-emerald-network)",
      "Bash(curl -s http://host.docker.internal:8444/realms/test-realm/protocol/openid-connect/certs)",
      "Bash(curl -s http://localhost:8080/actuator/env)",
      "Bash(echo \"JWT_ISSUER_URI: $JWT_ISSUER_URI\")",
      "Bash(echo \"JWT_JWK_SET_URI: $JWT_JWK_SET_URI\")",
      "Bash(awk '{print $2}')",
      "Bash(xargs -r kill)",
      "Bash(set -a)",
      "Bash(source .env)",
      "Bash(set +a)",
      "Bash(export)",
      "Bash(docker exec -it my-books-api-db-1 mysql -uroot -ppassword -D my-books-db -e \"SELECT id, email, name FROM users WHERE email = ''julia@gmail.com'' AND is_deleted = false;\")",
      "Bash(grep:*)",
      "Bash(pkill:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(xargs -I {} sh -c 'echo \"\"\"\"=== {} ===\"\"\"\" && head -20 {}')",
      "Bash(cat:*)",
      "Bash(rm:*)",
      "Bash(docker volume:*)",
      "Bash(docker compose:*)"
    ],
    "deny": []
  }
}
