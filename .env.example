DB_NAME=my-books-db
DB_URL=jdbc:mysql://db:3306/my-books-db
DB_USER=root
DB_PASSWORD=password

# OAuth2 Resource Server
# ⚠️ 重要: issとjwk-set-uriは異なる値を設定する必要があります
#
# JWT_ISSUER_URI: JWTトークンの"iss"クレーム検証用（ブラウザからアクセスするURL）
#                 BFFの.envのIDP_ISSUER_URIと完全一致させること
# JWT_JWK_SET_URI: JWKS取得用（コンテナからアクセスするURL）
#
# 【開発環境】Keycloakが別ネットワークの場合:
# - JWT_ISSUER_URI: ブラウザ用URL（BFFと同じ値）
# - JWT_JWK_SET_URI: host.docker.internalでホストマシン経由アクセス
#   例:
#   JWT_ISSUER_URI=http://auth.localhost:8444/realms/test-user-realm
#   JWT_JWK_SET_URI=http://host.docker.internal:8444/realms/test-user-realm/protocol/openid-connect/certs
#
# 【開発環境】Keycloakが同じネットワークの場合:
# - JWT_JWK_SET_URI: コンテナ名で直接アクセス
#   例:
#   JWT_ISSUER_URI=http://auth.localhost:8444/realms/test-user-realm
#   JWT_JWK_SET_URI=http://keycloak:8080/realms/test-user-realm/protocol/openid-connect/certs
#
# 【本番環境】公開URLを使用:
# - 両方とも同じ公開URLを使用
#   例:
#   JWT_ISSUER_URI=https://auth.example.com/realms/production-realm
#   JWT_JWK_SET_URI=https://auth.example.com/realms/production-realm/protocol/openid-connect/certs
#
# 他のIDプロバイダーの例:
# Auth0:
#   JWT_ISSUER_URI=https://your-tenant.auth0.com
#   JWT_JWK_SET_URI=https://your-tenant.auth0.com/.well-known/jwks.json
# Okta:
#   JWT_ISSUER_URI=https://dev-12345678.okta.com/oauth2/default
#   JWT_JWK_SET_URI=https://dev-12345678.okta.com/oauth2/default/v1/keys
# Azure AD:
#   JWT_ISSUER_URI=https://login.microsoftonline.com/{tenant-id}/v2.0
#   JWT_JWK_SET_URI=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys
JWT_ISSUER_URI=http://auth.localhost:8444/realms/test-user-realm
JWT_JWK_SET_URI=http://keycloak:8080/realms/test-user-realm/protocol/openid-connect/certs

# CORS設定（ブラウザからアクセスするURL）
# フロントエンド(5173) + BFF(8888)のホストマシン側URLを指定
# ⚠️ ワイルドカードは使用不可。具体的なポート番号を指定してください
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8888
