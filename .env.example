# ============================================
# Database Configuration
# ============================================
DB_NAME=my-books-db
DB_URL=jdbc:mysql://my-books-db:3306/my-books-db
DB_USER=root
DB_PASSWORD=password

# ============================================
# Identity Provider (IdP) Configuration
# ============================================
IDP_ISSUER_URI=https://vsv-crystal.skygroup.local/auth/realms/test-user-realm

# ============================================
# Development Environment Settings
# ============================================
# JPA Settings (開発環境ではSQLログを表示)
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true

# DataSource Pool Settings
DATASOURCE_POOL_MAX_SIZE=10
DATASOURCE_POOL_MIN_IDLE=5
DATASOURCE_CONNECTION_TIMEOUT=30000

# Error Response Settings (開発環境は詳細表示)
SERVER_ERROR_INCLUDE_MESSAGE=always
SERVER_ERROR_INCLUDE_STACKTRACE=always

# Logging (開発環境はDEBUGレベル)
LOGGING_LEVEL=DEBUG
